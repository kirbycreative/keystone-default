{
    "name": "keystone/laravel-toolkit",
    "description": "Reusable Laravel models, properties, forms, views, and UI assets.",
    "type": "library",
    "version": "1.0.0",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "illuminate/database": "^12.0",
        "illuminate/support": "^12.0",
        "illuminate/view": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "Keystone\\Toolkit\\": "src/"
        },
        "files": [
            "src/Helpers/Helper.php"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "Keystone\\Toolkit\\ToolkitServiceProvider"
            ]
        }
    }
}
